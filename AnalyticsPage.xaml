<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RaceTrackApp.AnalyticsPage"
             Title="Bet Analytics">

    <StackLayout Padding="20" Spacing="10">

        <Label Text="Bet History" FontSize="24" FontAttributes="Bold"/>

        <CollectionView x:Name="_historyList" VerticalOptions="FillAndExpand">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="10" Spacing="4">
                        <Label Text="{Binding Description}" FontAttributes="Bold"/>
                        <Label Text="{Binding Result}"/>
                        <Label Text="{Binding CashAfter}" TextColor="Gray"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Back" Clicked="OnBack"/>

    </StackLayout>
</ContentPage>